# Dev-only — Next.js auto-loads this when `npm run dev` is running.
# In dev the frontend (:3002) is a different origin from FastAPI (:8002),
# so the fetch client needs the absolute backend URL. Production builds
# don't load this file (NODE_ENV=production), so the fallback in
# web/lib/api.ts ("" → relative URLs) is what serves the same-origin
# walled-garden deploy.
NEXT_PUBLIC_API_BASE=http://localhost:8002
