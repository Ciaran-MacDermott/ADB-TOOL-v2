# Forecast Accuracy Deck Builder v2 — example env file.
# Copy to .env for local development. Never commit real secrets.

# ── NPD SSO ────────────────────────────────────────────────────────────
NPD_USERNAME=
NPD_PASSWORD=

# ── LLM providers (pick one path) ──────────────────────────────────────
# Free path: Groq + OpenRouter via direct HTTPS
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Paid path: Anthropic Claude / OpenAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Frontend ───────────────────────────────────────────────────────────
# Override only if the API runs on a non-default host/port in dev.
NEXT_PUBLIC_API_BASE=http://localhost:8000
