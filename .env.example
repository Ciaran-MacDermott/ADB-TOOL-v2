# Forecast Accuracy Deck Builder v2 — example env file.
# Copy to .env for local development. In production (walled-garden
# container) the orchestrator injects these directly; the .env file is
# only used when present.

# ── NPD External API ───────────────────────────────────────────────────
# Base URLs for prod (forecast data) and qa (actuals).
NPD_PROD_URL=https://future-of.npd.com
NPD_QA_URL=https://future-of-qa.npd.com
# Path suffixes — usually fine as-is.
NPD_API_PATH_INDUSTRIES=/api/ext/industries
NPD_API_PATH_FORECAST=/api/ext/industry/{id}/forecast

# Selenium SSO — bake Chromium + chromium-driver into the image.
# CHROME_BIN: path to the Chromium binary inside the container.
# CHROMEDRIVER_PATH: path to chromedriver (Selenium does NOT
# webdriver-manager-download at runtime).
# NPD_COOKIES_DIR: where to cache the 50-min cookie pickle so subsequent
# logins skip Selenium entirely. Must be writable by the container user.
CHROME_BIN=/usr/bin/chromium
CHROMEDRIVER_PATH=/usr/bin/chromedriver
NPD_COOKIES_DIR=/app/Cookies

# ── LLM providers ──────────────────────────────────────────────────────
# Live profiles route to Groq (brief / fast_writer / total_subheader)
# and Moonshot (writer / cleanup / fs_insight). Until the internal-LLM
# stub at src/llm/providers/internal_stub.py is wired, both are required.
GROQ_API_KEY=
MOONSHOT_API_KEY=
# Registered but no profile currently routes to it; safe to leave blank.
OPENROUTER_API_KEY=
# Legacy paid path — not used by the v2 free pipeline.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Runtime tuning ─────────────────────────────────────────────────────
# Max concurrent deck builds. Each one holds a Selenium-cookie session +
# may load pandas/pptx; 3 is comfortable on a 2-vCPU box.
ADB_MAX_RUN_SLOTS=3

# Comma-separated CORS allow-list. In production single-port deploy the
# frontend is same-origin so this should be empty. Set to the dev origin
# (http://localhost:3002) only for local development.
ADB_CORS_ORIGINS=

# ── Frontend ───────────────────────────────────────────────────────────
# Empty in production (frontend hits same origin). In dev when Next.js
# runs on :3002 and FastAPI on :8002, set to http://localhost:8002.
NEXT_PUBLIC_API_BASE=
